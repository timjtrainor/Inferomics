# ─── App Configuration ────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_ENV=local

# ─── Firestore (Google Cloud) ──────────────────────────────────────────────────
# Your GCP project ID (Found in GCP Console Dashboard)
FIRESTORE_PROJECT_ID=

# Use "(default)" or your custom Database ID
FIRESTORE_DATABASE_ID=(default)

# ─── Cloud Storage (Google Cloud) ─────────────────────────────────────────────
# Name of the bucket where .jsonl datasets are stored
GOOGLE_CLOUD_STORAGE_BUCKET=

# ─── Nebius Token Factory (Inference Engine) ───────────────────────────────────
# Get your API key from: https://docs.tokenfactory.nebius.com/
NEBIUS_API_KEY=
NEBIUS_BASE_URL=https://api.studio.nebius.ai/v1

# ─── Local Development Credentials ─────────────────────────────────────────────
# Path to your downloaded service-account.json key.
# IMPORTANT: On Cloud Run, this variable is ignored; it uses Workload Identity.
GOOGLE_APPLICATION_CREDENTIALS=./service-account.json