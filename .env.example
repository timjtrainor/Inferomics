# Inferomics — Environment Variables
# Copy this file to .env.local and fill in values.
# NEVER commit .env.local or service-account.json to git.

# ─── App ───────────────────────────────────────────────────────────────────────
# "local" shows dev indicators in UI; "production" hides them
NEXT_PUBLIC_APP_ENV=local

# ─── Firestore (Google Cloud) ──────────────────────────────────────────────────
# Your GCP project ID (e.g. "inferomics-demo")
FIRESTORE_PROJECT_ID=

# Firestore database name — leave as (default) unless you created a named database
FIRESTORE_DATABASE_ID=(default)

# ─── Local Auth Only ───────────────────────────────────────────────────────────
# Path to service account JSON for local dev connecting to live Firestore.
# NOT used in production (Cloud Run uses workload identity automatically).
GOOGLE_APPLICATION_CREDENTIALS=./service-account.json
